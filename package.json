{
  "name": "vue-naive-admin",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.1",
  "description": "A fresh and elegant admin template, based on Vue 3, Vite 6, TypeScript, Naive UI and UnoCSS.",
  "author": {
    "name": "Loic Duong",
    "email": "dploc96@gmail.com",
    "url": "https://github.com/loicduong"
  },
  "license": "MIT",
  "homepage": "https://github.com/loicduong/vue-naive-admin",
  "repository": {
    "url": "https://github.com/loicduong/vue-naive-admin.git"
  },
  "bugs": {
    "url": "https://github.com/loicduong/vue-naive-admin/issues"
  },
  "keywords": [
    "vue 3",
    "vite 6",
    "typescript",
    "naive-ui",
    "unocss"
  ],
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:tst": "vite build --mode testing",
    "commit": "commitlint --edit",
    "dev": "vite",
    "dev:prd": "vite --mode production",
    "dev:tst": "vite --mode testing",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@antv/data-set": "0.11.8",
    "@antv/g2": "5.4.8",
    "@antv/g6": "5.1.1",
    "@better-scroll/core": "2.5.1",
    "@iconify/vue": "5.0.1",
    "@sa/axios": "workspace:*",
    "@sa/color": "workspace:*",
    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@visactor/vchart": "2.0.22",
    "@visactor/vchart-theme": "1.12.3",
    "@visactor/vtable-editors": "1.26.1",
    "@visactor/vtable-gantt": "1.26.1",
    "@visactor/vue-vtable": "1.26.1",
    "@vue-flow/background": "1.3.2",
    "@vue-flow/core": "1.48.2",
    "@vueuse/components": "14.3.0",
    "@vueuse/core": "14.3.0",
    "ag-grid-community": "35.3.0",
    "ag-grid-vue3": "35.3.0",
    "axios": "1.16.0",
    "consola": "3.4.2",
    "d3": "7.9.0",
    "dayjs": "1.11.20",
    "defu": "6.1.7",
    "dhtmlx-gantt": "9.1.4",
    "echarts": "6.0.0",
    "html-to-image": "1.11.13",
    "intro.js": "8.3.2",
    "json-editor-vue": "0.18.1",
    "json5": "2.2.3",
    "jspdf": "4.2.1",
    "kolorist": "1.8.0",
    "naive-ui": "2.44.1",
    "pagedjs": "0.4.3",
    "pinia": "3.0.4",
    "signature_pad": "5.1.3",
    "swiper": "12.1.4",
    "tailwind-merge": "3.6.0",
    "typeit": "8.8.7",
    "vanilla-jsoneditor": "3.0.0",
    "vue": "3.5.34",
    "vue-draggable-plus": "0.6.1",
    "vue-i18n": "11.4.2",
    "vue-json-pretty": "2.6.0",
    "vue-pdf-embed": "2.1.4",
    "vue-router": "5.0.7",
    "vue3-google-map": "0.27.1",
    "wavesurfer.js": "7.12.6",
    "xgplayer": "3.0.24",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@iconify/json": "2.2.472",
    "@iconify/utils": "3.1.0",
    "@types/d3": "7.4.3",
    "@types/dagre": "0.7.54",
    "@types/html-minifier-terser": "7.0.2",
    "@types/intro.js": "5.1.5",
    "@types/node": "25.7.0",
