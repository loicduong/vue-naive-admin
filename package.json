    "vue-tsc": "3.2.8"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commit",
    "pre-commit": "pnpm typecheck && pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "volta": {
    "node": "22.14.0",
    "pnpm": "10.26.2"
  }
}
